--- !u!114 &1293791397
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1293791392}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 43b00979abff5324d9cfd72f54ec01d1, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  dialogue:
    name: Dialogue
    sentences:
    - 'Brother


      Amelia, What did the Wizard Say?'
    - 'Amelia


      He said I dont have much longer.'
    - 'Brother


      ... '
    - 'Amelia


      He did tell me about the Evil Witch that lives across the bridge,
      past the forrest.'
    - 'Amelia


      He said that she has a Magical Pineapple that can cure any
      disease.'
    - 'Brother


      Amelia, I will slay the witch and bring the pineapple to you!'
    - 'Amelia


      Be Safe'
